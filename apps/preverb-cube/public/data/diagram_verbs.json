    "micema": {
      "label": "მიცემა / giving (ditransitive)",
      "usedPreverbIds": [
        "mi",
        "mo"
      ],
      "annotations": {
        "mo": {
          "note": "With a first- or second-person recipient, the verb often takes მო-; the scene is anchored toward the speaker/listener (Ego Space).",
          "examples": [
            {
              "georgian": "მომცა",
              "gloss": "(S)he gave to me"
            },
            {
              "georgian": "მოგცა",
              "gloss": "(S)he gave to you (sg.)"
            },
            {
              "georgian": "მოგვცა",
              "gloss": "(S)he gave to us"
            },
            {
              "georgian": "მოგცათ",
              "gloss": "(S)he gave to you (pl.)"
            }
          ],
          "citation": "Rusudan Asatiani, Dynamic Conceptual Model of the Linguistic Structuring of Space: the Georgian Preverbs, section V (მო- with I/II person recipient and object marking)."
        },
        "mi": {
          "note": "With a third-person recipient, მი- is typical; orientation is toward the non-participant (Alter Space).",
          "examples": [
            {
              "georgian": "მივეცი",
              "gloss": "I gave to him/her"
            },
            {
              "georgian": "მიეცი",
              "gloss": "You (sg.) gave to him/her"
            },
            {
              "georgian": "მისცა",
              "gloss": "(S)he gave to him/her"
            }
          ],
          "citation": "Rusudan Asatiani, Dynamic Conceptual Model of the Linguistic Structuring of Space: the Georgian Preverbs, section V (მი- with III person recipient)."
        }
      }
    },
    "tseva": {
      "label": "წევა — to pull / drag (verbal-noun glosses below)",
