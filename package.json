{
  "name": "bagh",
  "version": "1.0.0",
  "description": "Bagh",
  "main": "dist/index.html",
  "scripts": {
    "build": "python build/build_pipeline.py --production",
    "dev:service": "python tools/dev/morphology_service_background.py start --host 127.0.0.1 --port 8765",
    "dev:service:stop": "python tools/dev/morphology_service_background.py stop",
    "dev:site": "python tools/dev/local_static_server.py --host 127.0.0.1 --port 8000",
    "dev": "python tools/dev/run_dev.py --host 127.0.0.1 --port 8000 --service-host 127.0.0.1 --service-port 8765 --open-url http://127.0.0.1:8000/dist/index.html",
    "clean": "rm -rf dist/"
  },
  "keywords": [
    "georgian",
    "language-learning",
    "verb-conjugation",
    "linguistics",
    "education",
    "interactive",
    "web-app"
  ],
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/c-host/bagh.git"
  },
  "fonts": {
    "description": "This project uses custom fonts for Georgian text display. See FONTS.md for licensing information.",
    "files": [
      "apps/bagh/assets/fonts/SonataNo5.otf",
      "apps/bagh/assets/fonts/NeueImpakt.otf",
      "apps/bagh/assets/fonts/k_gorga.ttf",
      "apps/bagh/assets/fonts/k_grigol.ttf",
      "apps/bagh/assets/fonts/k_kalig.ttf",
      "apps/bagh/assets/fonts/k_lortki.ttf"
    ]
  },
  "homepage": "https://github.com/c-host/bagh",
  "engines": {
    "node": ">=14.0.0"
  },
  "devDependencies": {},
  "dependencies": {}
}